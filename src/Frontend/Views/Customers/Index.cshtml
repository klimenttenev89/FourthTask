@model IEnumerable<CustomerListItemModel>
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Customers</h4>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Search by name or contact…" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <p class="text-muted">No customers found.</p>
}
else
{
    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Company</th>
                <th>Contact</th>
                <th>Country</th>
                <th class="text-center">Orders</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><code>@c.CustomerId</code></td>
                    <td>@c.CompanyName</td>
                    <td>@(c.ContactName ?? "—")</td>
                    <td>@(c.Country ?? "—")</td>
                    <td class="text-center">
                        <span class="badge bg-secondary">@c.OrderCount</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@c.CustomerId"
                           class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
